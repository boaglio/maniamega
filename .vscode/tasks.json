{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ROM",
            "type": "shell",
            "command": "./build.sh",
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
        {
            "label": "Build & Run (openMSX)",
            "type": "shell",
            "command": "./run.sh",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Run only (no build)",
            "type": "shell",
            "command": "./run.sh --no-build",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        }
    ]
}
