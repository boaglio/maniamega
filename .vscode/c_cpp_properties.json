{
    "version": 4,
    "configurations": [
        {
            "name": "MSXgl (SDCC Z80)",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/MSXgl/engine/src",
                "${workspaceFolder}/MSXgl/engine/src/**",
                "${workspaceFolder}/MSXgl/engine/content",
                "${workspaceFolder}/MSXgl/tools/sdcc/include"
            ],
            "defines": [
                "__SDCC",
                "MSX_VERSION=2"
            ],
            "compilerPath": "${workspaceFolder}/MSXgl/tools/sdcc/bin/sdcc",
            "cStandard": "c11",
            "intelliSenseMode": "linux-clang-x86",
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${workspaceFolder}/MSXgl/engine/src",
                    "${workspaceFolder}/MSXgl/engine/content"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}
